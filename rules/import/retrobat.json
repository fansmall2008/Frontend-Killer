{
  "frontend": "retrobat",
  "name": "RetroBat",
  "version": "1.0",
  "description": "Template for Importing Data and Media Files for the Pegasus Frontend.Including All Known Path Types",
  "type": "xml",
  "dataFile": "gamelist.xml",
  "delimiter": "",
  "rules": {
    "header": {
      "enabled": true,
      "format": "xml",
      "startMarker": "<provider>",
      "endMarker": "</provider>",
      "structure": [
        "collection: {platform.name}",
        "sort-by: {platform.sortBy}"
      ],
      "fields": {
        "platform.name": {
          "fields": ["System", "platform"],
          "isMultiValue": false
        },
        "platform.software": {
          "fields": ["software"],
          "isMultiValue": false
        },
        "platform.database": {
          "fields": ["database"],
          "isMultiValue": false
        },
        "platform.web": {
          "fields": ["web"],
          "isMultiValue": false
        },
        "platform.launch": {
          "fields": ["launch"],
          "isMultiValue": false
        },
        "platform.sortBy": {
          "fields": ["sort-by", "sort"],
          "isMultiValue": false
        },
        "platform.description": {
          "fields": ["description", "desc"],
          "isMultiValue": false
        }
      }
    },
    "fieldMappings": {
      "name": {
        "fields": ["name"],
        "isMultiValue": false
      },
      "description": {
        "fields": ["desc", "description"],
        "isMultiValue": false
      },
      "releaseDate": {
        "fields": ["releasedate", "release"],
        "isMultiValue": false
      },
      "developer": {
        "fields": ["developer", "dev"],
        "isMultiValue": false
      },
      "publisher": {
        "fields": ["publisher", "pub"],
        "isMultiValue": false
      },
      "genre": {
        "fields": ["genre", "category"],
        "isMultiValue": false
      },
      "players": {
        "fields": ["players", "player"],
        "isMultiValue": false
      },
      "files": {
        "fields": ["path", "file"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "rating": {
        "fields": ["rating"],
        "isMultiValue": false
      },
      "image": {
        "fields": ["image"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "video": {
        "fields": ["video"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "thumbnail": {
        "fields": ["thumbnail"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "marquee": {
        "fields": ["marquee"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "boxFront": {
        "fields": ["boxFront"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "boxBack": {
        "fields": ["boxBack"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "boxSpine": {
        "fields": ["boxSpine"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "boxFull": {
        "fields": ["boxFull"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "box3d": {
        "fields": ["box3d"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "screenshot": {
        "fields": ["screenshot"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "wheel": {
        "fields": ["wheel"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "fanart": {
        "fields": ["fanart"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "titlescreen": {
        "fields": ["titlescreen"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "banner": {
        "fields": ["banner"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "cartridge": {
        "fields": ["cartridge"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "logo": {
        "fields": ["logo"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "bezel": {
        "fields": ["bezel"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "panel": {
        "fields": ["panel"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "cabinetLeft": {
        "fields": ["cabinetLeft"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "cabinetRight": {
        "fields": ["cabinetRight"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "tile": {
        "fields": ["tile"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "steam": {
        "fields": ["steam"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "poster": {
        "fields": ["poster"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "background": {
        "fields": ["background"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      },
      "music": {
        "fields": ["music"],
        "isMultiValue": false,
        "transform": {
          "path": "no"
        }
      }
    },
    "media": {
      "boxFront": {
        "source": "boxFront",
        "rules": [
          "media/{filename}/boxFront.{ext}",
          "media/{filename}/box_front.{ext}",
          "media/boxFront/{filename}.{ext}",
          "media/box2dfront/{filename}.{ext}",
          "media/images/{filename}.{ext}"
        ],
        "transform": {
          "path": "no"
        }
      },
      "boxBack": {
        "source": "boxBack",
        "rules": [
          "media/{filename}/boxBack.{ext}",
          "media/{filename}/box_back.{ext}",
          "media/boxBack/{filename}.{ext}",
          "media/box2dback/{filename}.{ext}"
