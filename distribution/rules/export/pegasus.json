{
  "frontend": "pegasus",
  "name": "Pegasus Frontend",
  "version": "1.0",
  "description": "Pegasus frontend export rules",
  "rules": {
    "media": {
       "video": {
        "source": "video",
        "target": "{mediaPath}/{filename}/video.mp4",
        "dataFileTag": "assets.video"
      },
      "box2dfront": {
        "source": "box2dfront",
        "target": "{mediaPath}/{filename}/boxFront.png",
        "dataFileTag": "assets.boxFront"
      },
      "box2dback": {
        "source": "box2dback",
        "target": "{mediaPath}/{filename}/boxBack.png",
        "dataFileTag": "assets.boxBack"
      },
      "box3d": {
        "source": "box3d",
        "target": "{mediaPath}/{filename}/box3d.png",
        "dataFileTag": "assets.box3d"
      },
      "screenshot": {
        "source": "screenshot",
        "target": "{mediaPath}/{filename}/screenshot.png",
        "dataFileTag": "assets.screenshot"
      },
      
      "wheel": {
        "source": "wheel",
        "target": "{mediaPath}/{filename}/wheel.png",
        "dataFileTag": "assets.wheel"
      },
      "marquee": {
        "source": "marquee",
        "target": "{mediaPath}/{filename}/marquee.png",
        "dataFileTag": "assets.marquee"
      },
      "fanart": {
        "source": "fanart",
        "target": "{mediaPath}/{filename}/fanart.png",
        "dataFileTag": "assets.fanart"
      },
      "boxFull": {
        "source": "boxFull",
        "target": "{mediaPath}/{filename}/boxFull.png",
        "dataFileTag": "assets.boxFull"
      },
      "boxSpine": {
        "source": "boxSpine",
        "target": "{mediaPath}/{filename}/boxSpine.png",
        "dataFileTag": "assets.boxSpine"
      },
      "titlescreen": {
        "source": "titlescreen",
        "target": "{mediaPath}/{filename}/titlescreen.png",
        "dataFileTag": "assets.titlescreen"
      },
      "banner": {
        "source": "banner",
        "target": "{mediaPath}/{filename}/banner.png",
        "dataFileTag": "assets.banner"
      },
      "cartridge": {
        "source": "cartridge",
        "target": "{mediaPath}/{filename}/cartridge.png",
        "dataFileTag": "assets.cartridge"
      },
      "bezel": {
        "source": "bezel",
        "target": "{mediaPath}/{filename}/bezel.png",
        "dataFileTag": "assets.bezel"
      },
      "panel": {
        "source": "panel",
        "target": "{mediaPath}/{filename}/panel.png",
        "dataFileTag": "assets.panel"
      },
      "cabinetLeft": {
        "source": "cabinetLeft",
        "target": "{mediaPath}/{filename}/cabinetLeft.png",
        "dataFileTag": "assets.cabinetLeft"
      },
      "cabinetRight": {
        "source": "cabinetRight",
        "target": "{mediaPath}/{filename}/cabinetRight.png",
        "dataFileTag": "assets.cabinetRight"
      },
      "tile": {
        "source": "tile",
        "target": "{mediaPath}/{filename}/tile.png",
        "dataFileTag": "assets.tile"
      },
      "steam": {
        "source": "steam",
        "target": "{mediaPath}/{filename}/steam.png",
        "dataFileTag": "assets.steam"
      },
      "poster": {
        "source": "poster",
        "target": "{mediaPath}/{filename}/poster.png",
        "dataFileTag": "assets.poster"
      },
      "background": {
        "source": "background",
        "target": "{mediaPath}/{filename}/background.png",
        "dataFileTag": "assets.background"
      },
      "music": {
        "source": "music",
        "target": "{mediaPath}/{filename}/music.mp3",
        "dataFileTag": "assets.music"
      },
      "boxtexture": {
        "source": "boxtexture",
        "target": "{mediaPath}/{filename}/boxTexture.png",
        "dataFileTag": "assets.boxTexture"
      },
      "supporttexture": {
        "source": "supporttexture",
        "target": "{mediaPath}/{filename}/supportTexture.png",
        "dataFileTag": "assets.supportTexture"
      },
      "manual": {
        "source": "manual",
        "target": "{mediaPath}/{filename}/manual.pdf",
        "dataFileTag": "assets.manual"
      },
      "steamgrid": {
        "source": "steamgrid",
        "target": "{mediaPath}/{filename}/steamgrid.png",
        "dataFileTag": "assets.steamgrid"
      }
    },
    "dataFile": {
      "filename": "metadata.pegasus.txt",
      "format": "text",
      "pathFormat": "relative",
      "header": {
        "structure": [
          "collection: {platform.system}",
          "sort-by: 064",
          "{platform.launch}",
          ""
        ],
        "fields": {
          "platform.system": "{platform.system}",
          "platform.launch": "launch"
        }
      },
      "footer": [
        "# End of file"
      ],
      "fields": {
        "game": "name,translatedName",
        "files": "path",
        "description": "description,translatedDesc",
        "rating": "rating",
        "releaseDate": "releaseYear",
        "developer": "developer",
        "publisher": "publisher",
        "genre": "genre",
        "players": "players",
        "region": "region"
      },
      "fieldSeparator": "\n",
      "entrySeparator": "\n\n"
    },
    "directory": {
      "roms": "{outputPath}/{platform.system}",
      "media": "{outputPath}/{platform.system}/media"
    },
    "m3u": {
      "enabled": true,
      "target": "{romsPath}"
    }
  }
}