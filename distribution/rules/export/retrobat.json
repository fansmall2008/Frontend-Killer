      },
      "boxFull": {
        "source": "boxFull",
        "target": "{mediaPath}/boxFull/{filename}.png",
        "dataFileTag": "boxFull"
      },
      "banner": {
        "source": "banner",
        "target": "{mediaPath}/banner/{filename}.png",
        "dataFileTag": "banner"
      },
      "cartridge": {
        "source": "cartridge",
        "target": "{mediaPath}/cartridge/{filename}.png",
        "dataFileTag": "cartridge"
      },
      "bezel": {
        "source": "bezel",
        "target": "{mediaPath}/bezel/{filename}.png",
        "dataFileTag": "bezel"
      },
      "panel": {
        "source": "panel",
