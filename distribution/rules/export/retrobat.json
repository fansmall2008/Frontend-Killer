      },
      "steam": {
        "source": "steam",
        "target": "{mediaPath}/steam/{filename}.png",
        "dataFileTag": "steam"
      },
      "poster": {
        "source": "poster",
        "target": "{mediaPath}/poster/{filename}.png",
        "dataFileTag": "poster"
      },
      "background": {
        "source": "background",
        "target": "{mediaPath}/background/{filename}.png",
        "dataFileTag": "background"
      },
      "music": {
