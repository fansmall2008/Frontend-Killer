      "images": {
        "source": "images",
        "target": "{mediaPath}/images/{filename}.png",
        "dataFileTag": "images"
      }
    },
    "dataFile": {
      "filename": "gamelist.xml",
      "format": "xml",
      "pathFormat": "absoluteWithDot",
      "header": {
        "structure": [
          "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
          "<gameList>",
          "  <provider>",
          "    <System>{platform.system}</System>",
          "    <software>{platform.software}</software>",
          "    <database>{platform.database}</database>",
          "    <web>{platform.web}</web>",
          "  </provider>"
        ],
        "fields": {
          "platform.system": "system",
          "platform.software": "software",
          "platform.database": "database",
          "platform.web": "web"
        }
      },
      "footer": [
        "</gameList>"
      ],
      "fields": {
        "title": "name",
        "path": "path",
        "description": "description",
        "rating": "rating",
        "releaseDate": "releaseYear",
        "developer": "developer",
        "publisher": "publisher",
        "genre": "genre",
        "players": "players",
        "region": "region"
      }
    },
    "directory": {
      "roms": "{outputPath}/{platform}",
      "media": "{outputPath}/{platform}/media"
    }
  }
}