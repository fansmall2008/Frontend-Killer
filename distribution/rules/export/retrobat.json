        "dataFileTag": "screentitle"
      },
      "steamgrid": {
        "source": "steamgrid",
        "target": "{mediaPath}/steamgrid/{filename}.png",
        "dataFileTag": "steamgrid"
      },
      "support": {
        "source": "support",
        "target": "{mediaPath}/support/{filename}.png",
        "dataFileTag": "support"
      },
      "supporttexture": {
        "source": "supporttexture",
        "target": "{mediaPath}/supporttexture/{filename}.png",
        "dataFileTag": "supporttexture"
      },
      "video": {
        "source": "video",
        "target": "{mediaPath}/videos/{filename}.mp4",
        "dataFileTag": "video"
