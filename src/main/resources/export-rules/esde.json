{
  "frontend": "esde",
  "name": "EmulationStation DE",
  "version": "1.0",
  "description": "EmulationStation DE export rules",
  "rules": {
    "media": {
      "box2dfront": {
        "source": "box2dfront",
        "target": "{mediaPath}/box2dfront/{gameName}.png",
        "dataFileTag": "box2dfront"
      },
      "box2dback": {
        "source": "box2dback",
        "target": "{mediaPath}/box2dback/{gameName}.png",
        "dataFileTag": "box2dback"
      },
      "box3d": {
        "source": "box3d",
        "target": "{mediaPath}/box3d/{gameName}.png",
        "dataFileTag": "box3d"
      },
      "screenshot": {
        "source": "screenshot",
        "target": "{mediaPath}/screenshot/{gameName}.png",
        "dataFileTag": "screenshot"
      },
      "video": {
        "source": "video",
        "target": "{mediaPath}/video/{gameName}.mp4",
        "dataFileTag": "video"
      },
      "wheel": {
        "source": "wheel",
        "target": "{mediaPath}/wheel/{gameName}.png",
        "dataFileTag": "wheel"
      },
      "marquee": {
        "source": "marquee",
        "target": "{mediaPath}/marquee/{gameName}.png",
        "dataFileTag": "marquee"
      },
      "fanart": {
        "source": "fanart",
        "target": "{mediaPath}/fanart/{gameName}.png",
        "dataFileTag": "fanart"
      }
    },
    "dataFile": {
      "filename": "gamelist.xml",
      "format": "xml",
      "pathFormat": "absoluteWithDot",
      "header": {
        "structure": [
          "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
          "<gameList>",
          "  <provider>",
          "    <System>{platform.system}</System>",
          "    <software>ES-DE</software>",
          "    <database>ScreenScraper.fr</database>",
          "    <web>http://www.es-de.org</web>",
          "  </provider>"
        ],
        "fields": {
          "platform.system": "system"
        }
      },
      "footer": [
        "</gameList>"
      ],
      "fields": {
        "title": "name",
        "description": "description",
        "rating": "rating",
        "releaseDate": "releaseYear",
        "developer": "developer",
        "publisher": "publisher",
        "genre": "genre",
        "players": "players",
        "region": "region"
      }
    },
    "directory": {
      "roms": "{outputPath}/{platform}/roms",
      "media": "{outputPath}/{platform}/media"
    }
  }
}