{
  "frontend": "pegasus",
  "name": "Pegasus Frontend",
  "version": "1.0",
  "description": "Pegasus frontend export rules",
  "rules": {
    "media": {
       "video": {
        "source": "video",
        "target": "{mediaPath}/{gameName}/video.mp4",
        "dataFileTag": "assets.video"
      },
      "box2dfront": {
        "source": "box2dfront",
        "target": "{mediaPath}/{gameName}/boxFront.png",
        "dataFileTag": "assets.boxFront"
      },
      "box2dback": {
        "source": "box2dback",
        "target": "{mediaPath}/{gameName}/boxBack.png",
        "dataFileTag": "assets.boxBack"
      },
      "box3d": {
        "source": "box3d",
        "target": "{mediaPath}/{gameName}/box3d.png",
        "dataFileTag": "assets.box3d"
      },
      "screenshot": {
        "source": "screenshot",
        "target": "{mediaPath}/{gameName}/screenshot.png",
        "dataFileTag": "assets.screenshot"
      },
     
      "wheel": {
        "source": "wheel",
        "target": "{mediaPath}/{gameName}/wheel.png",
        "dataFileTag": "assets.wheel"
      },
      "marquee": {
        "source": "marquee",
        "target": "{mediaPath}/{gameName}/marquee.png",
        "dataFileTag": "assets.marquee"
      },
      "fanart": {
        "source": "fanart",
        "target": "{mediaPath}/{gameName}/fanart.png",
        "dataFileTag": "assets.fanart"
      }
    },
    "dataFile": {
      "filename": "metadata.pegasus.txt",
      "format": "text",
      "pathFormat": "relative",
      "header": {
        "structure": [
          "collection: {platform.system}",
          "sort-by: 064",
          "{platform.launch}",
          ""
        ],
        "fields": {
          "platform.system": "{platform.system}",
          "platform.launch": "launch"
        }
      },
      "footer": [
        "# End of file"
      ],
      "fields": {
        "game": "name,translatedName",
        "files": "path",
        "description": "description,translatedDesc",
        "rating": "rating",
        "releaseDate": "releaseYear",
        "developer": "developer",
        "publisher": "publisher",
        "genre": "genre",
        "players": "players",
        "region": "region"
      },
      "fieldSeparator": "\n",
      "entrySeparator": "\n\n"
    },
    "directory": {
      "roms": "{outputPath}/{platform.system}",
      "media": "{outputPath}/{platform.system}/media"
    },
    "m3u": {
      "enabled": true,
      "target": "{romsPath}"
    }
  }
}